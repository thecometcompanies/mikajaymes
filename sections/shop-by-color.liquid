<div class="shop-by-color color-{{ section.settings.color_scheme }} gradient" id="shopify-section-{{ section.id }}">
  <div class="container {{ section.settings.section_width }}">

    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="shop-by-color__header">
        {%- if section.settings.subheading != blank -%}
          <p class="shop-by-color__subheading">{{- section.settings.subheading | escape -}}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <{{ section.settings.heading_size }} class="shop-by-color__heading">
            {{- section.settings.heading | escape -}}
          </{{ section.settings.heading_size }}>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="shop-by-color__grid">
        {%- for block in section.blocks -%}
          {%- if block.type != 'color-card' -%}{%- continue -%}{%- endif -%}
          {%- assign card_link = block.settings.link | default: '#' -%}
          <a href="{{ card_link }}" class="shop-by-color__card block-{{ block.id }}" {{ block.shopify_attributes }}>
            <div class="shop-by-color__card-media">
              {%- if block.settings.image != blank -%}
                {%- render 'image', image: block.settings.image, loading: 'lazy' -%}
              {%- endif -%}
            </div>
            <div class="shop-by-color__card-content">
              {%- if block.settings.title != blank -%}
                <p class="shop-by-color__card-title">{{- block.settings.title | escape -}}</p>
              {%- endif -%}
              {%- if block.settings.subtitle != blank -%}
                <p class="shop-by-color__card-subtitle">{{- block.settings.subtitle | escape -}}</p>
              {%- endif -%}
              {%- if block.settings.cta_label != blank -%}
                <span class="shop-by-color__card-cta">{{- block.settings.cta_label | escape -}}</span>
              {%- endif -%}
            </div>
          </a>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</div>

{%- style -%}
  #shopify-section-{{ section.id }} {
    --sbc-aspect-ratio: {{ section.settings.card_aspect_ratio }};
    padding-block: calc(var(--section-spacing-unit-size) * {{ section.settings.spacing_top }}) calc(var(--section-spacing-unit-size) * {{ section.settings.spacing_bottom }});
  }
  #shopify-section-{{ section.id }} .shop-by-color__header {
    margin-block-end: 2.4rem;
    text-align: {{ section.settings.heading_alignment }};
  }
  #shopify-section-{{ section.id }} .shop-by-color__subheading {
    font-size: var(--font-size-static-xs);
    letter-spacing: var(--letter-spacing-medium);
    text-transform: uppercase;
    margin: 0 0 0.4rem;
    opacity: 0.7;
  }
  #shopify-section-{{ section.id }} .shop-by-color__heading {
    margin: 0;
  }
  #shopify-section-{{ section.id }} .shop-by-color__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.2rem;
  }
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .shop-by-color__grid {
      grid-template-columns: repeat({{ section.blocks.size | at_most: 5 | at_least: 1 }}, 1fr);
      gap: 1.6rem;
    }
  }
  #shopify-section-{{ section.id }} .shop-by-color__card {
    position: relative;
    display: block;
    aspect-ratio: var(--sbc-aspect-ratio);
    overflow: hidden;
    border-radius: var(--card-corner-radius, 0);
    text-decoration: none;
    color: inherit;
    isolation: isolate;
  }
  #shopify-section-{{ section.id }} .shop-by-color__card-media {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    z-index: 0;
  }
  #shopify-section-{{ section.id }} .shop-by-color__card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  #shopify-section-{{ section.id }} .shop-by-color__card::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.7) 0%, rgba(0, 0, 0, 0.35) 30%, rgba(0, 0, 0, 0) 55%);
    z-index: 1;
    pointer-events: none;
  }
  #shopify-section-{{ section.id }} .shop-by-color__card::before {
    content: "";
    position: absolute;
    inset: 0;
    background-color: rgba(0, 0, 0, 0);
    z-index: 1;
    pointer-events: none;
    transition: background-color 250ms ease;
  }
  #shopify-section-{{ section.id }} .shop-by-color__card:hover::before {
    background-color: rgba(0, 0, 0, 0.25);
  }
  #shopify-section-{{ section.id }} .shop-by-color__card-content {
    position: absolute;
    inset-inline: 0;
    inset-block-end: 0;
    padding: 2rem 2rem 2.2rem;
    z-index: 2;
    color: #ffffff;
  }
  #shopify-section-{{ section.id }} .shop-by-color__card-title {
    font-size: var(--font-size-static-lg);
    letter-spacing: var(--letter-spacing-medium);
    text-transform: uppercase;
    font-weight: 600;
    margin: 0;
    line-height: 1.2;
  }
  #shopify-section-{{ section.id }} .shop-by-color__card-subtitle {
    font-size: var(--font-size-static-md);
    line-height: 1.45;
    margin: 0.6rem 0 0;
    opacity: 0.95;
  }
  #shopify-section-{{ section.id }} .shop-by-color__card-cta {
    display: inline-block;
    margin-block-start: 1rem;
    font-size: var(--font-size-static-md);
    letter-spacing: var(--letter-spacing-medium);
    text-decoration: underline;
    text-underline-offset: 0.25em;
  }
  {%- for block in section.blocks -%}
    {%- if block.type == 'color-card' -%}
      #shopify-section-{{ section.id }} .block-{{ block.id }} .shop-by-color__card-media {
        background-color: {{ block.settings.color }};
      }
    {%- endif -%}
  {%- endfor -%}
{%- endstyle -%}

{% schema %}
{
  "name": "Shop by Color",
  "tag": "section",
  "class": "section-shop-by-color",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Eyebrow / caption (optional)"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Color"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" }
      ],
      "default": "h3"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Cards"
    },
    {
      "type": "select",
      "id": "card_aspect_ratio",
      "label": "Card aspect ratio",
      "options": [
        { "value": "1/1", "label": "Square 1:1" },
        { "value": "4/5", "label": "Portrait 4:5" },
        { "value": "3/4", "label": "Portrait 3:4" },
        { "value": "2/3", "label": "Portrait 2:3" }
      ],
      "default": "3/4"
    },
    {
      "type": "header",
      "content": "Section appearance"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "max-w-page", "label": "Page" },
        { "value": "max-w-fluid", "label": "Fluid" },
        { "value": "max-w-full", "label": "Full" }
      ],
      "default": "max-w-fluid"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Section color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "spacing_top",
      "label": "Spacing top",
      "options": [
        { "value": "0", "label": "0" },
        { "value": "2", "label": "2" },
        { "value": "4", "label": "4" },
        { "value": "6", "label": "6" },
        { "value": "8", "label": "8" }
      ],
      "default": "6"
    },
    {
      "type": "select",
      "id": "spacing_bottom",
      "label": "Spacing bottom",
      "options": [
        { "value": "0", "label": "0" },
        { "value": "2", "label": "2" },
        { "value": "4", "label": "4" },
        { "value": "6", "label": "6" },
        { "value": "8", "label": "8" }
      ],
      "default": "6"
    }
  ],
  "blocks": [
    {
      "type": "color-card",
      "name": "Color card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Color name",
          "default": "Color name"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Caption (optional)",
          "info": "Short description shown under the color name."
        },
        {
          "type": "color",
          "id": "color",
          "label": "Swatch color",
          "info": "Used as the card background — also the fallback when no image is uploaded.",
          "default": "#cccccc"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Product image (optional)"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "CTA label",
          "default": "Shop now"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop by Color",
      "blocks": [
        { "type": "color-card", "settings": { "title": "Silver Mink", "color": "#B5ACA1" } },
        { "type": "color-card", "settings": { "title": "Antique", "color": "#C9B89D" } },
        { "type": "color-card", "settings": { "title": "Camel", "color": "#B08A60" } },
        { "type": "color-card", "settings": { "title": "Dove Grey", "color": "#A8A6A1" } },
        { "type": "color-card", "settings": { "title": "True Green", "color": "#4A5D3A" } }
      ]
    }
  ]
}
{% endschema %}
