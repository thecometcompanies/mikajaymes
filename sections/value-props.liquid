<div class="value-props color-{{ section.settings.color_scheme }} gradient" id="shopify-section-{{ section.id }}">
  <div class="container {{ section.settings.section_width }}">

    {%- if section.settings.heading != blank -%}
      <div class="value-props__header">
        <{{ section.settings.heading_size }} class="value-props__heading">
          {{- section.settings.heading | escape -}}
        </{{ section.settings.heading_size }}>
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="value-props__grid">
        {%- for block in section.blocks -%}
          {%- if block.type != 'value-prop' -%}{%- continue -%}{%- endif -%}
          <article class="value-props__card" {{ block.shopify_attributes }}>
            <div class="value-props__card-media color-{{ block.settings.card_color_scheme }} gradient">
              {%- if block.settings.image != blank -%}
                {%- render 'image', image: block.settings.image, loading: 'lazy' -%}
              {%- endif -%}
            </div>
            <div class="value-props__card-content">
              {%- if block.settings.subtitle != blank -%}
                <p class="value-props__card-subtitle">
                  {%- if block.settings.subtitle_link != blank -%}
                    <a href="{{ block.settings.subtitle_link }}">{{- block.settings.subtitle | escape -}}</a>
                  {%- else -%}
                    {{- block.settings.subtitle | escape -}}
                  {%- endif -%}
                </p>
              {%- endif -%}
              {%- if block.settings.title != blank -%}
                <h6 class="value-props__card-title">
                  {%- if block.settings.title_link != blank -%}
                    <a href="{{ block.settings.title_link }}" class="value-props__card-title-link">{{- block.settings.title | escape -}}</a>
                  {%- else -%}
                    {{- block.settings.title | escape -}}
                  {%- endif -%}
                </h6>
              {%- endif -%}
              {%- if block.settings.body != blank -%}
                <div class="value-props__card-body rte">
                  {{- block.settings.body -}}
                </div>
              {%- endif -%}
            </div>
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</div>

{%- style -%}
  #shopify-section-{{ section.id }} {
    --vp-aspect-ratio: {{ section.settings.image_aspect_ratio }};
    padding-block: calc(var(--section-spacing-unit-size) * {{ section.settings.spacing_top }}) calc(var(--section-spacing-unit-size) * {{ section.settings.spacing_bottom }});
  }
  #shopify-section-{{ section.id }} .value-props__header {
    text-align: center;
    margin-block-end: 3.2rem;
  }
  #shopify-section-{{ section.id }} .value-props__heading {
    margin: 0;
  }
  #shopify-section-{{ section.id }} .value-props__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3.2rem;
  }
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .value-props__grid {
      grid-template-columns: repeat({{ section.blocks.size | at_most: 4 | at_least: 1 }}, 1fr);
      gap: 2.4rem;
    }
  }
  #shopify-section-{{ section.id }} .value-props__card {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }
  #shopify-section-{{ section.id }} .value-props__card-media {
    aspect-ratio: var(--vp-aspect-ratio);
    width: 100%;
    display: block;
    min-height: 8rem;
    overflow: hidden;
    border-radius: var(--card-corner-radius, 0);
    position: relative;
    background-color: rgb(var(--color-background));
  }
  #shopify-section-{{ section.id }} .value-props__card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  #shopify-section-{{ section.id }} .value-props__card-title-link {
    color: inherit;
    text-decoration: none;
    transition: opacity 200ms ease;
  }
  #shopify-section-{{ section.id }} .value-props__card-title-link:hover {
    opacity: 0.7;
    text-decoration: underline;
    text-underline-offset: 0.25em;
  }
  #shopify-section-{{ section.id }} .value-props__card-content {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding-inline: 0;
  }
  #shopify-section-{{ section.id }} .value-props__card-subtitle {
    font-size: var(--font-size-static-xs);
    letter-spacing: var(--letter-spacing-medium);
    text-transform: uppercase;
    color: rgb(var(--color-foreground) / 0.7);
    margin: 0;
  }
  #shopify-section-{{ section.id }} .value-props__card-subtitle a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 0.25em;
  }
  #shopify-section-{{ section.id }} .value-props__card-title {
    font-family: var(--font-heading-family);
    font-weight: var(--font-heading-weight);
    font-size: var(--font-size-static-lg);
    line-height: var(--line-height-static-md, 1.3);
    margin: 0;
  }
  #shopify-section-{{ section.id }} .value-props__card-body {
    font-size: var(--font-size-static-md);
    line-height: 1.55;
    color: rgb(var(--color-foreground) / 0.85);
  }
  #shopify-section-{{ section.id }} .value-props__card-body p {
    margin-block: 0;
  }
  #shopify-section-{{ section.id }} .value-props__card-body p + p {
    margin-block-start: 0.8rem;
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Value Props",
  "tag": "section",
  "class": "section-value-props",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "info": "Leave blank to hide the heading."
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" }
      ],
      "default": "h3"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "select",
      "id": "image_aspect_ratio",
      "label": "Image aspect ratio",
      "options": [
        { "value": "1/1", "label": "Square 1:1" },
        { "value": "4/5", "label": "Portrait 4:5" },
        { "value": "3/4", "label": "Portrait 3:4" },
        { "value": "4/3", "label": "Landscape 4:3" },
        { "value": "16/9", "label": "Wide 16:9" }
      ],
      "default": "1/1"
    },
    {
      "type": "header",
      "content": "Section appearance"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "max-w-page", "label": "Page" },
        { "value": "max-w-fluid", "label": "Fluid" },
        { "value": "max-w-full", "label": "Full" }
      ],
      "default": "max-w-page"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Section color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "spacing_top",
      "label": "Spacing top",
      "options": [
        { "value": "0", "label": "0" },
        { "value": "2", "label": "2" },
        { "value": "4", "label": "4" },
        { "value": "6", "label": "6" },
        { "value": "8", "label": "8" }
      ],
      "default": "6"
    },
    {
      "type": "select",
      "id": "spacing_bottom",
      "label": "Spacing bottom",
      "options": [
        { "value": "0", "label": "0" },
        { "value": "2", "label": "2" },
        { "value": "4", "label": "4" },
        { "value": "6", "label": "6" },
        { "value": "8", "label": "8" }
      ],
      "default": "6"
    }
  ],
  "blocks": [
    {
      "type": "value-prop",
      "name": "Value prop card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "color_scheme",
          "id": "card_color_scheme",
          "label": "Card placeholder color (shown when no image)",
          "default": "scheme-2"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Caption (optional)",
          "info": "Small caption above the title (e.g. 'Normandy, France')."
        },
        {
          "type": "url",
          "id": "subtitle_link",
          "label": "Caption link (optional)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "url",
          "id": "title_link",
          "label": "Title link (optional)",
          "info": "If set, the title becomes a clickable link."
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Body copy"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Value Props",
      "blocks": [
        {
          "type": "value-prop",
          "settings": {
            "title": "Premium Fibers",
            "body": "<p>We source materials chosen for how they feel, not just how they look. Breathable cotton, fluid modal, and refined linen blends form the foundation of every piece.</p>"
          }
        },
        {
          "type": "value-prop",
          "settings": {
            "title": "Cut and Sewn in Los Angeles",
            "body": "<p>Each garment is cut and sewn locally in Los Angeles, with attention placed on balance, proportion, and structure. Nothing oversized. Nothing excessive. Just precise construction.</p>"
          }
        },
        {
          "type": "value-prop",
          "settings": {
            "title": "Designed to Feel Right",
            "body": "<p>Light on the body. Structured where it matters. Designed to move naturally and hold its shape over time.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
