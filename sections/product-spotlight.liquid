<div class="product-spotlight color-{{ section.settings.color_scheme }} gradient" id="shopify-section-{{ section.id }}">
  <div class="product-spotlight__media color-{{ section.settings.media_color_scheme }} gradient">
    {%- if section.settings.image != blank -%}
      {%- render 'image', image: section.settings.image, loading: 'lazy' -%}
    {%- endif -%}

    <div class="product-spotlight__overlay product-spotlight__overlay--{{ section.settings.content_position }}">
      <div class="product-spotlight__content">
        {%- if section.settings.subtitle != blank -%}
          <p class="product-spotlight__subtitle">{{- section.settings.subtitle | escape -}}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <{{ section.settings.heading_size }} class="product-spotlight__heading">
            {{- section.settings.heading | escape -}}
          </{{ section.settings.heading_size }}>
        {%- endif -%}

        {%- if section.settings.body != blank -%}
          <div class="product-spotlight__body rte">
            {{- section.settings.body -}}
          </div>
        {%- endif -%}

        {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
          <div class="product-spotlight__cta">
            <a href="{{ section.settings.button_link }}" class="product-spotlight__button">
              {{- section.settings.button_label | escape -}}
            </a>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{%- style -%}
  #shopify-section-{{ section.id }} {
    --ps-aspect-ratio-mobile: {{ section.settings.aspect_ratio_mobile }};
    --ps-aspect-ratio-desktop: {{ section.settings.aspect_ratio_desktop }};
    padding-block: calc(var(--section-spacing-unit-size) * {{ section.settings.spacing_top }}) calc(var(--section-spacing-unit-size) * {{ section.settings.spacing_bottom }});
  }
  #shopify-section-{{ section.id }} .product-spotlight__media {
    position: relative;
    width: 100%;
    aspect-ratio: var(--ps-aspect-ratio-mobile);
    display: block;
    min-height: 28rem;
    overflow: hidden;
    background-color: rgb(var(--color-background));
  }
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .product-spotlight__media {
      aspect-ratio: var(--ps-aspect-ratio-desktop);
      min-height: 36rem;
    }
  }
  #shopify-section-{{ section.id }} .product-spotlight__media > img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  #shopify-section-{{ section.id }} .product-spotlight__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    padding: 2.4rem;
    z-index: 1;
  }
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .product-spotlight__overlay {
      padding-inline: clamp(3.2rem, 6vw, 8rem);
    }
  }
  #shopify-section-{{ section.id }} .product-spotlight__overlay--left { justify-content: flex-start; }
  #shopify-section-{{ section.id }} .product-spotlight__overlay--center { justify-content: center; text-align: center; }
  #shopify-section-{{ section.id }} .product-spotlight__overlay--right { justify-content: flex-end; text-align: right; }
  #shopify-section-{{ section.id }} .product-spotlight__content {
    max-width: 48rem;
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
    color: rgb(var(--color-foreground));
  }
  #shopify-section-{{ section.id }} .product-spotlight__subtitle {
    font-size: var(--font-size-static-xs);
    letter-spacing: var(--letter-spacing-medium);
    text-transform: uppercase;
    margin: 0;
    opacity: 0.85;
  }
  #shopify-section-{{ section.id }} .product-spotlight__heading {
    margin: 0;
    font-family: var(--font-heading-family);
    font-weight: var(--font-heading-weight);
    line-height: 1.15;
  }
  #shopify-section-{{ section.id }} .product-spotlight__body {
    font-size: var(--font-size-static-md);
    line-height: 1.55;
    opacity: 0.9;
  }
  #shopify-section-{{ section.id }} .product-spotlight__body p {
    margin-block: 0;
  }
  #shopify-section-{{ section.id }} .product-spotlight__body p + p {
    margin-block-start: 0.6rem;
  }
  #shopify-section-{{ section.id }} .product-spotlight__cta {
    margin-block-start: 0.4rem;
  }
  #shopify-section-{{ section.id }} .product-spotlight__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 2rem;
    border: 1px solid currentColor;
    background: transparent;
    color: inherit;
    font-size: var(--font-size-static-sm);
    letter-spacing: var(--letter-spacing-medium);
    text-decoration: none;
    transition: background-color 200ms ease, color 200ms ease;
    border-radius: var(--btn-corner-radius, 0);
  }
  #shopify-section-{{ section.id }} .product-spotlight__button:hover {
    background-color: rgb(var(--color-foreground));
    color: rgb(var(--color-background));
  }
{%- endstyle -%}

{% schema %}
{
  "name": "Product spotlight",
  "tag": "section",
  "class": "section-product-spotlight",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "color_scheme",
      "id": "media_color_scheme",
      "label": "Image placeholder color (shown when no image)",
      "default": "scheme-2"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Eyebrow / caption (optional)"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "A New Perspective on Performance Apparel"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" }
      ],
      "default": "h3"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body copy"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Content position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "aspect_ratio_desktop",
      "label": "Desktop aspect ratio",
      "options": [
        { "value": "21/9", "label": "Cinematic 21:9" },
        { "value": "21/8", "label": "Ultra-wide 21:8" },
        { "value": "16/7", "label": "Wide 16:7" },
        { "value": "16/9", "label": "Wide 16:9" },
        { "value": "3/1", "label": "Banner 3:1" }
      ],
      "default": "21/8"
    },
    {
      "type": "select",
      "id": "aspect_ratio_mobile",
      "label": "Mobile aspect ratio",
      "options": [
        { "value": "1/1", "label": "Square 1:1" },
        { "value": "4/5", "label": "Portrait 4:5" },
        { "value": "4/3", "label": "Landscape 4:3" },
        { "value": "3/2", "label": "Landscape 3:2" }
      ],
      "default": "4/5"
    },
    {
      "type": "header",
      "content": "Section appearance"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Section color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "spacing_top",
      "label": "Spacing top",
      "options": [
        { "value": "0", "label": "0" },
        { "value": "2", "label": "2" },
        { "value": "4", "label": "4" },
        { "value": "6", "label": "6" },
        { "value": "8", "label": "8" }
      ],
      "default": "0"
    },
    {
      "type": "select",
      "id": "spacing_bottom",
      "label": "Spacing bottom",
      "options": [
        { "value": "0", "label": "0" },
        { "value": "2", "label": "2" },
        { "value": "4", "label": "4" },
        { "value": "6", "label": "6" },
        { "value": "8", "label": "8" }
      ],
      "default": "0"
    }
  ],
  "presets": [
    {
      "name": "Product spotlight"
    }
  ]
}
{% endschema %}
